{
  "name": "iot-midterm-availability-mqtt",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "broker:configure": "cmake -S broker -B broker/build",
    "broker:build": "cmake --build broker/build",
    "broker:clean": "rm -rf broker/build",
    "broker:test": "cmake --build broker/build && ctest --test-dir broker/build --output-on-failure"
  }
}
